{
  "name": "ADLS_Dataset",
  "properties": {
    "linkedServiceName": {
      "referenceName": "AzureDataLakeStorage",
      "type": "LinkedServiceReference"
    },
    "parameters": {
      "folderPath": {
        "type": "String"
      },
      "fileName": {
        "type": "String"
      }
    },
    "type": "DelimitedText",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "bronze",
        "folderPath": "@dataset().folderPath",
        "fileName": "@dataset().fileName"
      }
    }
  }
}
